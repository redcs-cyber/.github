# Mode: local | hybrid
JARVIS_MODE=local

# Audio
SAMPLE_RATE=16000
CHUNK_SECONDS=3

# Whisper
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Ollama
OLLAMA_URL=http://127.0.0.1:11434/api/chat
OLLAMA_MODEL=llama3.1:8b

# OpenAI (hybrid mode)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Piper
PIPER_EXE=C:\tools\piper\piper.exe
PIPER_MODEL=C:\tools\piper\tr_TR-dfki-medium.onnx
PIPER_OUTPUT_WAV=C:\jarvis\out.wav

# Wake word
WAKEWORD=jarvis
WAKEWORD_MODEL_PATH=

# MCP
MCP_SERVERS_FILE=C:\jarvis\mcp_servers.json

# Telemetry
TELEMETRY_FILE=C:\jarvis\telemetry\events.jsonl
